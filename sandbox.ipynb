   "source": [
    "import numpy as np\n",
    "from microtorch.tensor import Tensor, functional as F\n",
    "\n",
    "x = Tensor(np.array([1, 2, 3, 4, 5], dtype=np.float32), requires_grad=True)\n",
    "y = x*x\n",
    "z = F.max(y)\n",
    "z.backward()"
   ]
  },
